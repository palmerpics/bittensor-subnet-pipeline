# --- Taostats ---
TAOSTATS_API_KEY=your-key-from-taostats.io/pro

# --- Cloudflare R2 (S3-compatible credentials from an R2 API token) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET=bittensor-lake

# --- Alerts (optional) ---
DISCORD_WEBHOOK_URL=
ALERT_FLOW_Z=2.5
ALERT_PRICE_DROP_7D=-0.15
ALERT_DEREG_WITHIN=5

# --- Local dev overrides (leave unset in CI) ---
# BRONZE_ROOT=fixtures/bronze
# GOLD_ROOT=transform/target/gold
